# Django
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost,.vercel.app

# Database (Option A: PostgreSQL — recommended for production)
DATABASE_URL=postgres://user:password@host:5432/rittikdesk

# Database (Option B: SQLite fallback — for local dev)
USE_SQLITE_FALLBACK=True

# Database (Option C: manual PostgreSQL config — used when DATABASE_URL is not set and USE_SQLITE_FALLBACK=False)
DB_NAME=rittikdesk
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Email (production)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=RittikDesk AI <noreply@rittikdesk.com>

# Cloudinary (optional — for image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# OpenRouter AI
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

# AI tuning (optional)
OPENROUTER_FALLBACK_MODELS=
AI_TIMEOUT=30
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2048
