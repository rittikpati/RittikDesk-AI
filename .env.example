# ==========================================
# Django Settings
# ==========================================

SECRET_KEY=your-secret-key-here

DEBUG=True

ALLOWED_HOSTS=127.0.0.1,localhost,.vercel.app

DJANGO_SETTINGS_MODULE=rittikdesk.settings


# ==========================================
# Database Configuration
# ==========================================

# Production PostgreSQL URL (Example)
DATABASE_URL=postgresql://username:password@host/database?sslmode=require

# Local PostgreSQL Fallback
DB_NAME=rittikdesk
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Set True for local SQLite development
USE_SQLITE_FALLBACK=True


# ==========================================
# Cloudinary (Optional)
# ==========================================

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=


# ==========================================
# OpenRouter AI Configuration
# ==========================================

# Get your API key from:
# https://openrouter.ai/

OPENROUTER_API_KEY=your-openrouter-api-key

# OpenRouter Base URL
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Primary AI Model
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

# Fallback Models (comma-separated)
OPENROUTER_FALLBACK_MODELS=qwen/qwen3-next-80b-a3b-instruct:free,meta-llama/llama-3.3-70b-instruct:free

# AI Request Settings
AI_TIMEOUT=30
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2048


# ==========================================
# Future Optional APIs
# ==========================================

RESEND_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
REDIS_URL=