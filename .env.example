SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,.vercel.app

# PostgreSQL (Neon) - Required for production
DATABASE_URL=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/rittikdesk?sslmode=require

# PostgreSQL connection details (fallback if no DATABASE_URL)
DB_NAME=rittikdesk
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Set to True to use SQLite as local fallback
USE_SQLITE_FALLBACK=False

# Cloudinary (Optional - runs without it)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# DeepSeek API
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_URL=https://api.deepseek.com/v1

# Django
DJANGO_SETTINGS_MODULE=rittikdesk.settings
